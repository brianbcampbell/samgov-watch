# SAM.gov API key — register at https://sam.gov/profile/details
# Required for individual opportunity lookups (update/monitor phase)
SAM_API_KEY=your_sam_gov_api_key_here

# ── SharePoint (required for --output sharepoint) ─────────────────────────
# Azure AD app registration (needs Sites.ReadWrite.All or Sites.Selected)
SP_TENANT_ID=your-tenant-id
SP_CLIENT_ID=your-client-id
SP_CLIENT_SECRET=your-client-secret

# Run `samgov-sync get-site-id` to find the site ID
# List IDs live in searches.toml per profile (sharepoint_list_id)
SP_SITE_ID=your-sharepoint-site-id

# ── Discord (required for --output discord) ───────────────────────────────
# discord.com/developers → New Application → Bot → copy token
# Bot needs: Send Messages, Create Public Threads, Send Messages in Threads, Embed Links
DISCORD_BOT_TOKEN=your-bot-token-here

# Channel IDs are set per-profile in searches.toml (discord_channel_id)
# This is only needed as a fallback if a profile has no discord_channel_id
# DISCORD_CHANNEL_ID=your-forum-channel-id

# Where to persist thread/message IDs (default shown — relative to working dir)
# DISCORD_STATE_FILE=state/.discord_state.json
